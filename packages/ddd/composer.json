{
    "name": "solidframe/ddd",
    "description": "DDD building blocks: ValueObject, Entity, AggregateRoot, Specification for SolidFrame",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulkadir Posul",
            "email": "abdulkadir-posul@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "solidframe/core": "^0.1"
    },
    "autoload": {
        "psr-4": {
            "SolidFrame\\Ddd\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SolidFrame\\Ddd\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
