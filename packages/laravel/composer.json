{
    "name": "solidframe/laravel",
    "description": "Laravel bridge for SolidFrame architectural packages",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulkadir Posul",
            "email": "abdulkadir-posul@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "solidframe/core": "^0.1",
        "illuminate/console": "^10.0 || ^11.0 || ^12.0",
        "illuminate/contracts": "^10.0 || ^11.0 || ^12.0",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "solidframe/ddd": "DDD building blocks (Entity, ValueObject, AggregateRoot)",
        "solidframe/cqrs": "CQRS support (CommandBus, QueryBus)",
        "solidframe/event-driven": "Event-driven architecture (EventBus)",
        "solidframe/event-sourcing": "Event sourcing (EventStore, Snapshots)",
        "solidframe/modular": "Modular monolith support",
        "solidframe/saga": "Saga / Process Manager support"
    },
    "autoload": {
        "psr-4": {
            "SolidFrame\\Laravel\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SolidFrame\\Laravel\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "SolidFrame\\Laravel\\SolidFrameServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "0.1.x-dev"
        }
    },
    "config": {
        "sort-packages": true
    }
}
