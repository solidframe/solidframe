{
    "name": "solidframe/core",
    "description": "Core interfaces, base classes, Result type, and Pipeline for SolidFrame",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulkadir Posul",
            "email": "abdulkadir-posul@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SolidFrame\\Core\\": "src/"
        }
