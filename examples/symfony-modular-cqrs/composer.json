{
    "name": "solidframe/example-symfony-modular-cqrs",
    "type": "project",
    "description": "SolidFrame example: E-commerce with Modular Monolith, CQRS and Saga in Symfony",
    "keywords": ["solidframe", "modular", "cqrs", "saga", "symfony", "example"],
    "license": "MIT",
    "minimum-stability": "dev",
    "prefer-stable": true,
    "repositories": [
        {"type": "path", "url": "../../packages/core"},
        {"type": "path", "url": "../../packages/ddd"},
        {"type": "path", "url": "../../packages/cqrs"},
        {"type": "path", "url": "../../packages/event-driven"},
        {"type": "path", "url": "../../packages/modular"},
        {"type": "path", "url": "../../packages/saga"},
        {"type": "path", "url": "../../packages/archtest"},
        {"type": "path", "url": "../../packages/phpstan-rules"},
        {"type": "path", "url": "../../packages/symfony"}
    ],
    "require": {
        "php": ">=8.4",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "doctrine/dbal": "^4.4.3",
        "solidframe/cqrs": "@dev",
        "solidframe/ddd": "@dev",
        "solidframe/event-driven": "@dev",
        "solidframe/modular": "@dev",
        "solidframe/saga": "@dev",
        "solidframe/symfony": "@dev",
        "symfony/console": "8.0.*",
        "symfony/dotenv": "8.0.*",
        "symfony/flex": "^2.10",
        "symfony/framework-bundle": "8.0.*",
        "symfony/runtime": "8.0.*",
        "symfony/validator": "8.0.*",
        "symfony/yaml": "8.0.*"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5.19",
        "solidframe/archtest": "@dev",
        "solidframe/phpstan-rules": "@dev",
        "symfony/browser-kit": "8.0.*",
        "symfony/phpunit-bridge": "8.0.*"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "bump-after-update": true,
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*",
        "symfony/polyfill-php83": "*",
        "symfony/polyfill-php84": "*"
    },
    "scripts": {
        "auto-scripts": {
            "cache:clear": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd"
        },
        "post-install-cmd": [
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "@auto-scripts"
        ],
        "test": "phpunit"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": false,
            "require": "8.0.*"
        }
    }
}
