{
    "name": "solidframe/solidframe",
    "description": "SolidFrame - Modern architectural packages for PHP",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Abdulkadir Posul",
            "email": "abdulkadir-posul@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "solidframe/core": "@dev",
        "solidframe/cqrs": "@dev",
        "solidframe/ddd": "@dev",
        "solidframe/event-driven": "@dev",
        "solidframe/event-sourcing": "@dev",
        "solidframe/modular": "@dev",
        "solidframe/archtest": "@dev",
        "solidframe/phpstan-rules": "@dev",
        "solidframe/saga": "@dev",
        "solidframe/laravel": "@dev",
        "solidframe/symfony": "@dev",
        "doctrine/dbal": "^3.0 || ^4.0",
        "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
        "friendsofphp/php-cs-fixer": "^3.94",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0",
        "rector/rector": "^2.3"
    },
    "scripts": {
        "cs:check": "php-cs-fixer fix --dry-run --diff",
        "cs:fix": "php-cs-fixer fix",
        "analyse": "phpstan analyse",
        "rector:check": "rector process --dry-run",
        "rector:fix": "rector process",
        "test": "phpunit",
        "qa": ["@cs:check", "@analyse", "@rector:check", "@test"],
        "qa:fix": ["@cs:fix", "@rector:fix"]
    },
    "autoload-dev": {
        "psr-4": {
            "SolidFrame\\Archtest\\Tests\\": "packages/archtest/tests/",
            "SolidFrame\\PHPStanRules\\Tests\\": "packages/phpstan-rules/tests/",
            "SolidFrame\\Laravel\\Tests\\": "packages/laravel/tests/",
            "SolidFrame\\Symfony\\Tests\\": "packages/symfony/tests/"
        },
        "classmap": [
            "packages/phpstan-rules/tests/Rules/Cqrs/data",
            "packages/phpstan-rules/tests/Rules/Ddd/data",
            "packages/phpstan-rules/tests/Rules/EventSourcing/data"
        ]
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/*"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true
}
